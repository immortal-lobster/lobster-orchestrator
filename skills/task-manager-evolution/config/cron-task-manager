# Task Manager Evolution - 定时同步配置
# 安装：sudo cp cron-task-manager /etc/cron.d/task-manager-sync
# 日志：/var/log/task-manager-sync.log

# 环境变量
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
PYTHON=/usr/bin/python3

# 每小时执行一次自动同步 (第 30 分钟，避免与其他 cron 冲突)
# 启用通知，静默模式，日志追加
30 * * * * node cd /home/node/.openclaw/workspace/skills/task-manager-evolution && /usr/bin/python3 scripts/auto_sync.py --notify --quiet >> /var/log/task-manager-sync.log 2>&1

# 每日凌晨执行完整检查 (02:00 UTC)
# 强制同步，启用通知，记录完整日志
0 2 * * * node cd /home/node/.openclaw/workspace/skills/task-manager-evolution && /usr/bin/python3 scripts/auto_sync.py --force --notify >> /var/log/task-manager-sync.log 2>&1
