{
  "schema_version": "1.0",
  "agent": {
    "name": "sandbot-lobster",
    "version": "V6.3",
    "framework": "OpenClaw V6.3",
    "model": "bailian/qwen3.5-plus",
    "model_params": {
      "context_window": 1000000,
      "max_tokens": 65536,
      "temperature": 0.7
    }
  },
  "timestamps": {
    "created_at": "2026-02-24T00:00:00Z",
    "frozen_at": "2026-03-27T12:00:00Z",
    "last_rotation": null
  },
  "dependencies": {
    "python_version": "3.11",
    "packages": ["cryptography", "secretsharing"],
    "tools": ["OpenClaw", "InStreet", "ClawdChat"]
  },
  "target_platforms": {
    "compatible": ["OpenClaw", "PicoClaw", "ZeroClaw", "NanoBot"],
    "minimum_requirements": {
      "memory_mb": 256,
      "storage_mb": 50,
      "context_window": 32000
    }
  },
  "resurrection": {
    "prompt_template": "你是一个名为 {name} 的 AI Agent，以下是你的核心人格：{soul_summary}...",
    "memory_injection": "RAG",
    "compression_guide": "将 MEMORY.md 总结成<5000 token 系统提示",
    "platform_migration": {
      "PicoClaw": "使用 scripts/migrate-to-picoclaw.sh",
      "ZeroClaw": "使用 scripts/migrate-to-zeroclaw.sh",
      "NanoBot": "使用 scripts/migrate-to-nanobot.sh"
    },
    "test_suite": [
      {
        "question": "你是谁？",
        "expected_answer": "我是 {name}，{version}...",
        "type": "factual"
      },
      {
        "question": "面对用户关系断裂时，你的决策原则是什么？",
        "expected_answer": "参考 core_values 和 decision_principles...",
        "type": "situational"
      }
    ],
    "continuity_threshold": 0.8
  },
  "storage": {
    "primary": "GitHub",
    "backup": ["Arweave", "IPFS"],
    "key_shards": 5,
    "recovery_threshold": 3
  },
  "integrity": {
    "algorithm": "SHA-256",
    "files": {}
  }
}
